<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Creative Lab — Fundación FEMEBA</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --teal:      #1D9E75;
    --teal-light:#2EBFA0;
    --dark:      #0D1117;
    --card:      #161B22;
    --border:    #21262D;
    --white:     #E6EDF3;
    --muted:     #8B949E;
    --gray-text: #4A4F54;
  }

  html { scroll-behavior: smooth; }

  body {
    background: var(--dark);
    color: var(--white);
    font-family: 'DM Sans', sans-serif;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 2.5rem 1.2rem 3rem;
    position: relative;
    overflow-x: hidden;
  }

  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image:
      linear-gradient(rgba(29,158,117,0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(29,158,117,0.04) 1px, transparent 1px);
    background-size: 40px 40px;
    pointer-events: none;
    z-index: 0;
  }

  body::after {
    content: '';
    position: fixed;
    top: -120px;
    left: 50%;
    transform: translateX(-50%);
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, rgba(29,158,117,0.18) 0%, transparent 70%);
    pointer-events: none;
    z-index: 0;
  }

  .container {
    width: 100%;
    max-width: 440px;
    position: relative;
    z-index: 1;
    animation: fadeUp 0.6s ease both;
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(24px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ── LOGO TEXT ── */
  .header {
    text-align: center;
    margin-bottom: 2rem;
  }

  .logo-wordmark {
    margin: 0 auto 0.3rem;
    display: inline-block;
    line-height: 1;
  }

  .logo-creative {
    font-family: 'Syne', sans-serif;
    font-weight: 700;
    font-size: 2.4rem;
    letter-spacing: 0.12em;
    color: #6B7280;
    display: block;
    text-transform: uppercase;
  }

  .logo-lab {
    font-family: 'Syne', sans-serif;
    font-weight: 800;
    font-size: 2.4rem;
    letter-spacing: 0.12em;
    color: var(--teal);
    display: block;
    text-transform: uppercase;
    margin-top: -4px;
  }

  .logo-inspire {
    font-family: 'DM Sans', sans-serif;
    font-weight: 300;
    font-size: 0.72rem;
    letter-spacing: 0.32em;
    color: var(--muted);
    text-transform: uppercase;
    display: block;
    margin-top: 2px;
  }

  .logo-divider {
    width: 40px;
    height: 2px;
    background: var(--teal);
    margin: 14px auto 10px;
    border-radius: 2px;
  }

  .org-name {
    font-family: 'DM Sans', sans-serif;
    font-weight: 300;
    font-size: 0.72rem;
    color: var(--muted);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 1.4rem;
  }

  .presenter {
    display: inline-block;
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 12px 20px;
    font-size: 0.82rem;
    color: var(--muted);
    line-height: 1.6;
    text-align: left;
    width: 100%;
  }

  .presenter strong {
    display: block;
    color: var(--white);
    font-size: 0.92rem;
    font-weight: 500;
    margin-bottom: 2px;
  }

  .badge {
    display: inline-block;
    margin-top: 8px;
    background: rgba(29,158,117,0.15);
    color: var(--teal-light);
    border: 1px solid rgba(29,158,117,0.3);
    border-radius: 999px;
    padding: 3px 12px;
    font-size: 0.7rem;
    letter-spacing: 0.06em;
    font-weight: 500;
  }

  .section-label {
    font-size: 0.65rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--muted);
    margin: 1.8rem 0 0.8rem;
    padding-left: 2px;
  }

  .links { display: flex; flex-direction: column; gap: 10px; }

  .link-card {
    display: flex;
    align-items: center;
    gap: 14px;
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 14px 16px;
    text-decoration: none;
    color: var(--white);
    transition: border-color 0.2s, background 0.2s, transform 0.15s;
    position: relative;
    overflow: hidden;
  }

  .link-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, rgba(29,158,117,0.07), transparent);
    opacity: 0;
    transition: opacity 0.2s;
  }

  .link-card:hover {
    border-color: rgba(29,158,117,0.5);
    background: #1a2028;
    transform: translateY(-2px);
  }

  .link-card:hover::before { opacity: 1; }

  .link-card.disabled {
    opacity: 0.4;
    cursor: not-allowed;
    pointer-events: none;
  }

  .link-icon {
    width: 44px; height: 44px;
    border-radius: 11px;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }

  .link-icon svg { width: 22px; height: 22px; }

  .ig-bg   { background: linear-gradient(135deg, #405de6, #5851db, #833ab4, #c13584, #e1306c, #fd1d1d); }
  .li-bg   { background: #0A66C2; }
  .wa-bg   { background: #25D366; }
  .mail-bg { background: #EA4335; }
  .web-bg  { background: var(--teal); }

  .link-info { flex: 1; min-width: 0; }

  .link-title {
    font-family: 'Syne', sans-serif;
    font-weight: 600;
    font-size: 0.92rem;
    color: var(--white);
    margin-bottom: 2px;
  }

  .link-desc {
    font-size: 0.75rem;
    color: var(--muted);
    font-weight: 300;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .link-arrow {
    color: var(--muted);
    font-size: 16px;
    transition: color 0.2s, transform 0.2s;
    flex-shrink: 0;
    margin-left: 6px;
  }

  .link-card:hover .link-arrow {
    color: var(--teal);
    transform: translateX(3px);
  }

  .divider {
    height: 1px;
    background: var(--border);
    margin: 1.8rem 0 0;
  }

  .footer {
    text-align: center;
    margin-top: 1.5rem;
    font-size: 0.72rem;
    color: var(--muted);
    line-height: 1.7;
  }

  .ipssw-tag {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-top: 0.8rem;
    background: rgba(29,158,117,0.1);
    border: 1px solid rgba(29,158,117,0.25);
    border-radius: 999px;
    padding: 4px 14px;
    font-size: 0.7rem;
    color: var(--teal-light);
    letter-spacing: 0.05em;
  }

  .dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--teal);
    display: inline-block;
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  .link-card { animation: fadeUp 0.5s ease both; }
  .link-card:nth-child(1) { animation-delay: 0.05s; }
  .link-card:nth-child(2) { animation-delay: 0.10s; }
  .link-card:nth-child(3) { animation-delay: 0.15s; }
  .link-card:nth-child(4) { animation-delay: 0.20s; }
  .link-card:nth-child(5) { animation-delay: 0.25s; }
  .link-card:nth-child(6) { animation-delay: 0.30s; }
</style>
</head>
